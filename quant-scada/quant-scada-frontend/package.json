{
  "name": "quant-scada-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --mode dev",
    "build": "vue-tsc && vite build --mode prod",
    "preview": "vite preview",
    "electron:dev": "concurrently --kill-others \"vite --mode dev\" \"wait-on http://localhost:5173 && electron electron/main.js\"",
    "electron:build": "vite build --mode prod && electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vue-tsc": "^2.0.6",
    "wait-on": "^7.2.0"
  }
}
